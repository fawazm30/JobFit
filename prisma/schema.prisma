generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  onboardingComplete Boolean  @default(false)
  industries         String[]
  jobTitles          String[]
  locations          String[]
  jobTypes           String[]

  resumeUrl      String?
  resumeText     String?
  resumeFileName String?

  skills String[]

  jobPostings     JobPosting[]
}

model JobPosting {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title           String
  company         String
  location        String?
  description     String
  applicationLink String?
  
  source          String   @default("manual") // "manual" or "adzuna"
  externalId      String?  // for deduplication of auto-discovered jobs
  
  matchScore      Int?     // 0-100, calculated by Claude
  matchReason     String?  // short explanation of the match
  
  matchedSkills String[]
  missingSkills String[]
  interestMatch String?
  
  status          String   @default("saved") // saved, applied, interviewing, rejected, offered
  applicationStatus String? // interested, applied, interview, rejected, offer, ghosted
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, externalId])

  requirements String[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}